<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OSD to Discord Bridge"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Discord Webhook URLs (one per line):"
        android:textSize="14sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etWebhookUrls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="https://discord.com/api/webhooks/...\nhttps://discord.com/api/webhooks/..."
        android:inputType="textMultiLine"
        android:lines="4"
        android:gravity="top"
        android:minHeight="48dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnSaveWebhooks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Webhooks"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnTestWebhooks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Test Webhooks"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/swBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Run in Background"
        android:checked="true"
        android:layout_marginBottom="32dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Stopped"
        android:textSize="18sp"
        android:textColor="#777777"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnToggleMonitoring"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Monitoring"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

</LinearLayout>
